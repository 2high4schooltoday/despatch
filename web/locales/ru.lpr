--- launchpad-rosetta 1
locale: ru
fallback: en
plural-rule: one few many other

[Core Patterns]
selected_count
  {count: cardinal}
  | one = {count} выбрано
  | few = {count} выбрано
  | many = {count} выбрано
  | other = {count} выбрано

recipient_count
  {count: cardinal}
  | one = {count} получатель
  | few = {count} получателя
  | many = {count} получателей
  | other = {count} получателя

message_count
  {count: cardinal}
  | one = {count} сообщение
  | few = {count} сообщения
  | many = {count} сообщений
  | other = {count} сообщения

unread_count
  {count: cardinal}
  | one = {count} непрочитанное
  | few = {count} непрочитанных
  | many = {count} непрочитанных
  | other = {count} непрочитанного

skipped_duplicate_count
  {count: cardinal}
  | one = , пропущен {count} дубликат
  | few = , пропущено {count} дубликата
  | many = , пропущено {count} дубликатов
  | other = , пропущено {count} дубликата

group_recipients_none_added = Новые получатели из группы «{label}» не добавлены.
group_recipients_added = Из группы «{label}» добавлено {insertedText}{duplicateText}.
device_approval_other_devices = Подтвердите этот вход с одного из {count} других устройств, где вы уже вошли в систему.
device_approval_another_device = Подтвердите этот вход с другого устройства, где вы уже вошли в систему.
bulk_registration_result_failed = {action} регистраций: успешно {appliedCount}, ошибок {failedCount} ({preview})
bulk_registration_result_ok = {action} регистраций: {appliedCount}
suspend_selected_users_body = {count} выбранных пользователей потеряют доступ, пока их снова не разблокируют.
bulk_user_result_failed = {action} пользователей: успешно {appliedCount}, ошибок {failedCount} ({preview})
bulk_user_result_ok = {action} пользователей: {appliedCount}

